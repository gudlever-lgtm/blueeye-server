PORT=3000
WS_PORT=4000
DB_PATH=/data/blueeye.db
RCA_URL=http://blueeye-rca:5000
RCA_ENABLED=true

# License validation against blueeye-licenseserver. Set at install time (not CRUD).
# Enforcement is OFF unless LICENSE_KEY is set.
# LICENSE_KEY=BLUEEYE-CUSTOMER-0001
# SERVER_ID=srv-unique-id
# LICENSE_SERVER_URL=http://blueeye-licenseserver:4100
# LICENSE_CACHE_PATH=/data/license-cache.json
# Optional overrides (defaults shown):
# LICENSE_POLL_INTERVAL_MS=21600000   # 6h
# LICENSE_GRACE_MS=1209600000         # 14d offline grace
# The public key is embedded in the build; override only for rotation/testing:
# LICENSE_PUBLIC_KEY_PATH=keys/license_public.pem
