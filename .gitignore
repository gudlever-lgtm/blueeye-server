# Dependencies
node_modules/

# Local environment / secrets
.env
.env.local

# Cached license validation
.license-cache.json

# Persisted analysis baselines
.analysis-baselines.json

# Cross-compiled agent binaries cached at runtime for enrolment downloads
# (agentBinaryCacheDir, src/enroll/agentBinaryStore.js) — generated, never tracked.
agent-binaries/

# Local compose overrides (e.g. host port tweaks)
docker-compose.override.yml

# GeoIP build inputs/outputs (downloaded/built into the repo dir during setup) —
# keep them untracked so they never trip deploy.sh's "uncommitted changes" guard.
dbip-*.csv
dbip-*.csv.gz
/geoip.csv

# Logs
*.log
logs/

# Test / coverage output
coverage/
.nyc_output/

# OS / editor cruft
.DS_Store
.idea/
.vscode/
*.swp
