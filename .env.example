PORT=3000
WS_PORT=4000
DB_PATH=/data/blueeye.db
RCA_URL=http://blueeye-rca:5000
RCA_ENABLED=true

# --- License validation (set once at install time; not editable via the API) ---
# Enforcement turns on automatically when LICENSE_KEY is set. Force it on/off
# with LICENSE_ENABLED=true|false.
LICENSE_KEY=
SERVER_ID=
LICENSE_SERVER_URL=http://blueeye-licens:6000
# Override the embedded public key only if you run your own license server.
# LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
# LICENSE_ENABLED=true
# LICENSE_GRACE_DAYS=14
# LICENSE_VALIDATE_INTERVAL_MS=21600000
# LICENSE_CACHE_PATH=/data/license-cache.json
