# BlueEye server — example configuration.
# Copy to `.env` and adjust for your environment:  cp .env.example .env

# Runtime
NODE_ENV=development
PORT=3000

# MySQL connection (on-prem, single-tenant)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=blueeye
DB_PASSWORD=change-me
DB_NAME=blueeye

# Connection pool
DB_CONNECTION_LIMIT=10

# Authentication / JWT
# Generate a long random value, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h
JWT_ISSUER=blueeye-server
# bcrypt cost factor (higher = slower = stronger)
BCRYPT_ROUNDS=12

# Initial admin user — seeded on first migration if no admin exists.
# If SEED_ADMIN_PASSWORD is left empty, a random one is generated and printed once.
SEED_ADMIN_EMAIL=admin@blueeye.local
SEED_ADMIN_PASSWORD=change-me

# Enrollment
# Default lifetime of a new enrollment code, in minutes (here: 1 hour).
ENROLLMENT_CODE_TTL_MINUTES=60

# Frictionless enrollment (download + one-line install)
# Canonical URL clients use to reach this server (e.g. behind a reverse proxy).
# When unset, the enrollment endpoints derive it from the incoming request.
# BLUEEYE_PUBLIC_URL=https://blueeye.example.dk
# Directory holding the agent binaries served at /enroll/agent/:platform.
# Name files blueeye-agent-<platform>[.exe], e.g. blueeye-agent-linux-amd64.
# AGENT_ARTIFACTS_DIR=./artifacts
# SHA-256 fingerprint of the server's TLS leaf cert (or the terminating proxy's),
# embedded into install scripts so the agent can pin it. Leave unset for plain
# HTTP / development. Accepts "AB:CD:…", "abcd…" or "sha256:AB:CD:…".
# AGENT_CERT_FINGERPRINT=

# Agent WebSocket
WS_AGENT_PATH=/ws/agent
# Browser WebSocket (live analysis findings pushed to the dashboard)
WS_DASHBOARD_PATH=/ws/dashboard
WS_HEARTBEAT_MS=30000

# Licensing (validated against blueeye-licens; set at installation, not via API)
LICENSE_KEY=
LICENSE_SERVER_ID=
LICENSE_SERVER_URL=http://localhost:4000
# Embedded Ed25519 public key from blueeye-licens (docs/public-key.md). Prefer
# editing src/license/publicKey.js; this env var (PEM or base64-of-PEM) overrides it.
LICENSE_PUBLIC_KEY=
# Offline grace period (days) and validation interval (hours).
LICENSE_GRACE_DAYS=14
LICENSE_VALIDATE_INTERVAL_HOURS=6
# Where the last verified validation is cached.
LICENSE_CACHE_PATH=./.license-cache.json

# Storage monitoring: path to check for disk free/used space. Point this at the
# drive holding the DB/Docker volume. In compose the server mounts /data, which
# typically shares the host drive with the db volume.
STORAGE_DISK_PATH=/data

# Analysis module (local, explainable anomaly detection)
ANALYSIS_ENABLED=true
# AI assistant (opt-in, OFF by default). When enabled it answers questions about
# a host using only the recent findings as context, via Mistral's API.
ANALYSIS_ASSISTANT_ENABLED=false
# API key for the assistant (falls back to MISTRAL_API_KEY). Required only when
# the assistant is enabled. Never logged; sent only to the provider.
ANALYSIS_ASSISTANT_API_KEY=
ANALYSIS_ASSISTANT_MODEL=mistral-small-latest
ANALYSIS_ASSISTANT_URL=https://api.mistral.ai/v1/chat/completions
# Cap on how many recent findings are sent as context, and the request timeout.
ANALYSIS_ASSISTANT_MAX_FINDINGS=20
ANALYSIS_ASSISTANT_TIMEOUT_MS=20000
# Detector tuning
ANALYSIS_CRIT_SIGMA=4.0
ANALYSIS_WARN_SIGMA=3.0
ANALYSIS_BASELINE_DAYS=7
ANALYSIS_MIN_SAMPLES=200
# Where warmed-up baselines are persisted (survive restart)
ANALYSIS_BASELINE_CACHE_PATH=./.analysis-baselines.json

# Geo enrichment of flow records (country + ASN). RFC1918/private endpoints are
# never geolocated. Point GEOIP_DB_PATH at an offline, EU-sourced GeoIP/ASN range
# CSV (e.g. DB-IP Lite — Belgium/EU, CC-BY). See docs/geo.md. Without it, flows
# are still stored but without country/ASN.
GEO_ENABLED=true
GEOIP_DB_PATH=
# Map tiles for the Geo view, served to the frontend via /api/geo/config (never
# hardcoded). Default is OpenStreetMap (OSMF, EU); for production point this at a
# self-hosted or other EU tile source — never a US tile server.
MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
MAP_TILE_ATTRIBUTION=© OpenStreetMap contributors
MAP_TILE_MAX_ZOOM=19
# Geocoder for the location address search/picker (forward + reverse). Default
# OpenStreetMap Nominatim (OSMF, EU); use a self-hosted/EU instance in
# production. Editable at runtime under Settings → Map.
MAP_GEOCODE_URL=https://nominatim.openstreetmap.org

# Alerting: forward findings to channels. OFF by default. Per-channel minimum
# severity (default webhook=CRIT, syslog=INFO, email=WARN) and a per
# (host,metric,kind) cooldown so the same condition doesn't spam.
ALERTING_ENABLED=false
ALERT_COOLDOWN_MS=900000
# Email (SMTP via nodemailer if installed; point at a European/self-hosted host)
ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_MIN_SEVERITY=WARN
ALERT_EMAIL_FROM=blueeye@localhost
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
# Webhook (HMAC-SHA256 signed payload; receiver verifies X-BlueEye-Signature)
ALERT_WEBHOOK_ENABLED=false
ALERT_WEBHOOK_MIN_SEVERITY=CRIT
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_SECRET=
# Syslog (RFC5424; forwardable to Cisco ISE). CRIT→err, WARN→warning, INFO→info.
ALERT_SYSLOG_ENABLED=false
ALERT_SYSLOG_MIN_SEVERITY=INFO
SYSLOG_HOST=
SYSLOG_PORT=514
SYSLOG_PROTO=udp
SYSLOG_APP=blueeye

# Retention + rollup: down-sample old raw data and purge expired data nightly.
# ON by default (DB hygiene). Raw data is kept rawDays; aggregated rollups
# rollupDays; findings findingDays (only ACKED findings are ever purged).
RETENTION_ENABLED=true
RETENTION_RAW_DAYS=7
RETENTION_ROLLUP_DAYS=90
RETENTION_FINDING_DAYS=365
RETENTION_ROLLUP_INTERVAL_MINUTES=60
RETENTION_JOB_INTERVAL_HOURS=24
