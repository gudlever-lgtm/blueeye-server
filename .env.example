DATABASE_URL=postgresql+asyncpg://blueeye:blueeye@postgres:5432/blueeye
SECRET_KEY=change-me-to-something-random
PUBLIC_BASE_URL=http://localhost:8000

# SMTP (leave SMTP_HOST blank to log password-reset emails to stdout instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=BlueEye <noreply@blueeye.local>

# Mollie payments (BlackEye upgrade)
MOLLIE_API_KEY=
BLACKEYE_ANNUAL_PRICE_EUR=499.00

# Platform licensing (leave LICENSE_SERVER_URL or LICENSE_KEY blank to run
# unlicensed — default tier blueeye, free agent quota).
LICENSE_SERVER_URL=
LICENSE_KEY=
LICENSE_VALIDATE_INTERVAL_SECONDS=86400
LICENSE_GRACE_PERIOD_SECONDS=604800
LICENSE_FREE_TIER_MAX_AGENTS=5

# Created by scripts/seed.py
DEFAULT_SUPERADMIN_EMAIL=admin@blueeye.local
DEFAULT_SUPERADMIN_PASSWORD=admin
