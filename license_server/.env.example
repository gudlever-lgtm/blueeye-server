DATABASE_URL=postgresql+asyncpg://license:license@postgres:5432/licenses
SECRET_KEY=license-dev-secret-please-change

# Ed25519 signing key. EITHER paste the PEM directly here:
LICENSE_PRIVATE_KEY_PEM=
# OR point to a file (mount as a Docker secret in production):
LICENSE_PRIVATE_KEY_FILE=/run/secrets/license_private_key.pem

LICENSE_JWT_TTL_SECONDS=7200

DEFAULT_ADMIN_EMAIL=admin@license.local
DEFAULT_ADMIN_PASSWORD=admin
