# BlueEye server — example configuration.
# Copy to `.env` and adjust for your environment:  cp .env.example .env

# Runtime
NODE_ENV=development
PORT=3000

# MySQL connection (on-prem, single-tenant)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=blueeye
DB_PASSWORD=change-me
DB_NAME=blueeye

# Connection pool
DB_CONNECTION_LIMIT=10

# Authentication / JWT
# Generate a long random value, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=12h
JWT_ISSUER=blueeye-server
# bcrypt cost factor (higher = slower = stronger)
BCRYPT_ROUNDS=12

# Initial admin user — seeded on first migration if no admin exists.
# If SEED_ADMIN_PASSWORD is left empty, a random one is generated and printed once.
SEED_ADMIN_EMAIL=admin@blueeye.local
SEED_ADMIN_PASSWORD=change-me

# Enrollment
# Default lifetime of a new enrollment code, in minutes (here: 1 hour).
ENROLLMENT_CODE_TTL_MINUTES=60
