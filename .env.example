# BlueEye server — example configuration.
# Copy to `.env` and adjust for your environment:  cp .env.example .env

# Runtime
NODE_ENV=development
PORT=3000

# MySQL connection (on-prem, single-tenant)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=blueeye
DB_PASSWORD=change-me
DB_NAME=blueeye

# Connection pool
DB_CONNECTION_LIMIT=10
