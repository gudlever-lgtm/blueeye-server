PORT=3000
WS_PORT=4000
DB_PATH=/data/blueeye.db
RCA_URL=http://blueeye-rca:5000
RCA_ENABLED=true

# Shared HMAC secret for verifying agent WebSocket tokens. REQUIRED — if unset,
# all agent WS connections are rejected (fail closed).
# Generate with: openssl rand -hex 32
WS_AGENT_SECRET=

# REST RBAC: comma-separated key:role pairs. Roles: viewer < operator < admin.
# Write endpoints (e.g. POST /tests) require operator or admin.
# Example: API_KEYS=adminkey:admin,opkey:operator,viewkey:viewer
API_KEYS=
